# ─── Rivet Console — Environment Variables ───────────────────────────────────
# Copy this file to .env.local for local development.
# NEVER commit .env.local — it is in .gitignore.
#
# For Cloudflare Pages production deployment, add these in:
# Dashboard → Pages → rivet-console → Settings → Environment variables
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL (found in: Supabase Dashboard → Project Settings → API)
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase anon/public key (found in: Supabase Dashboard → Project Settings → API)
# This is safe to expose in the frontend — RLS policies protect your data
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Rivet Core backend URL — your Replit deployment
# e.g. https://rivet-core.yourusername.repl.co
VITE_RIVET_API_URL=https://your-replit-slug.repl.co

# Telegram bot username WITHOUT the @ symbol
# Used for the "Open bot" deep link on the Home tab
# e.g. if your bot is @RivetAIBot, put: RivetAIBot
VITE_BOT_USERNAME=YourBotUsername
